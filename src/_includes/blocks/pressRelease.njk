<div class="press-release">
    <div class="inner-container" style="margin-left:{{ marginLeft }};margin-right:{{ marginRight }};">
        {% if title %}
            <h2>{{ title }}</h2>
        {% endif %}
        {% if date %}
            <p class="press-release-date">{{ date }}</p>
        {% endif %}
        {% if subtitle %}
            <h3>{{ subtitle }}</h3>
        {% endif %}
        {% if desc %}
            {% if end %}
                <p class="last-paragraph">{{ desc | safe }}</p>
            {% else %}
                <p>{{ desc | safe }}</p>
            {% endif %}
        {% endif %}
        {% if list %}
            <ul>
                {% for item in list %}
                    <li>{{ item | safe }}</li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>
