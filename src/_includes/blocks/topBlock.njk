<section class="top-block">
    <div class="container">
        <div class="triangle-background">
            <div class="large-logo">
                <img id="" src="{{ img.url }}" />
            </div>
            <div class="version">4.0</div>
        </div>
    </div>
    <div class="container-info">
        <div class="text-part">
            <h1>{{ title }}</h1>
            <h2>{{ title2 }}</h2>
            <h2 class="last-subtitle">{{ title3 }}</h2>
            <span>{{ desc }}</span>
        </div>
        <div class="logo-part">
            <ul>
                {% for item in items %}
                <li>
                    <a href="{{ item.link }}" class="logo-part-link" target="_blank">
                        <div class="icon-back">
                            <img class="backImage" src="/../assets/img/HexButtonStates.svg">
                            <img class="iconImage" src="{{ item.img.url }}">
                        </div>
                        <div class="logo-part-desc">{{ item.desc }}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container">
        <div class="middle-triangle">
        </div>
    </div>
</section>
