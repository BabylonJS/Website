{
    "name": "babylonjs-website",
    "version": "2.0.0",
    "description": "",
    "main": "eleventy.config.js",
    "scripts": {
        "start": "npx @11ty/eleventy --serve",
        "site:build": "npx @11ty/eleventy",
        "build": "npm run site:build && npm run demos:build && npm run demos:pure:build",
        "demos:lint": "eslint \"vite.demos.config.mjs\" \"scripts/**/*.mjs\" \"src/compiledDemos/**/*.ts\"",
        "demos:format": "prettier --check \"azure-pipelines.yml\" \"azure-pipelines.compiled-demos.yml\" \"docs/compiled-demos.md\" \"docs/deployment.md\" \"eslint.config.mjs\" \"package.json\" \"scripts/**/*.mjs\" \"src/compiledDemos/**/*.{html,json,ts}\" \"src/pureCompiledDemos/**/*.{html,json,ts}\" \"tsconfig.demos.json\" \"tsconfig.pure-demos.json\" \"vite.demos.config.mjs\" \"vite.pure-demos.config.mjs\"",
        "demos:format:write": "prettier --write \"azure-pipelines.yml\" \"azure-pipelines.compiled-demos.yml\" \"docs/compiled-demos.md\" \"docs/deployment.md\" \"eslint.config.mjs\" \"package.json\" \"scripts/**/*.mjs\" \"src/compiledDemos/**/*.{html,json,ts}\" \"src/pureCompiledDemos/**/*.{html,json,ts}\" \"tsconfig.demos.json\" \"tsconfig.pure-demos.json\" \"vite.demos.config.mjs\" \"vite.pure-demos.config.mjs\"",
        "demos:build": "vite build --config vite.demos.config.mjs && node scripts/demos/generate-source-pages.mjs",
        "demos:serve": "npm run build && vite preview --host 127.0.0.1 --port 4173 --outDir build",
        "demos:typecheck": "tsc -p tsconfig.demos.json --noEmit",
        "demos:smoke": "node scripts/demos/check-smoke.mjs",
        "demos:check": "node scripts/demos/check-render.mjs",
        "demos:ci": "npm run demos:lint && npm run demos:format && npm run demos:typecheck && npm run demos:check",
        "demos:pure:lint": "eslint \"vite.pure-demos.config.mjs\" \"src/pureCompiledDemos/**/*.ts\"",
        "demos:pure:typecheck": "tsc -p tsconfig.pure-demos.json --noEmit",
        "demos:pure:build": "vite build --config vite.pure-demos.config.mjs && DEMOS_SOURCE_ROOT=src/pureCompiledDemos DEMOS_OUTPUT_ROOT=PureDemos DEMOS_MANIFEST_PATH=src/pureCompiledDemos/manifest.json node scripts/demos/generate-source-pages.mjs",
        "demos:pure:smoke": "DEMOS_MANIFEST_PATH=src/pureCompiledDemos/manifest.json DEMOS_BASE_PATH=PureDemos node scripts/demos/check-smoke.mjs",
        "demos:pure:check": "DEMOS_MANIFEST_PATH=src/pureCompiledDemos/manifest.json DEMOS_BASE_PATH=PureDemos node scripts/demos/check-render.mjs",
        "demos:pure:ci": "npm run demos:pure:lint && npm run demos:format && npm run demos:pure:typecheck && npm run demos:pure:build && npm run demos:pure:check",
        "deploy:package": "node scripts/deploy/create-deploy-package.mjs",
        "process-images": "node .github/scripts/process-images.js",
        "update-image": "node .github/scripts/update-image.js",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "",
    "license": "Apache2",
    "dependencies": {
        "@11ty/eleventy": "^3.1.5",
        "sharp": "^0.33.5"
    },
    "devDependencies": {
        "@babylonjs/core": "^9.9.1",
        "@babylonjs/gui": "^9.9.1",
        "@babylonjs/inspector": "^9.9.1",
        "@babylonjs/loaders": "^9.9.1",
        "@babylonjs/materials": "^9.9.1",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.3.0",
        "globals": "^17.6.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.16"
    }
}
