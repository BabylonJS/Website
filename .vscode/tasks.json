{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "eleventy serve",
            "type": "shell",
            "command": "npm start",
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "group": "watch"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": ".*Eleventy.*error.*",
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": ".*Writing.*"
                    },
                    "endsPattern": {
                        "regexp": ".*Wrote.*"
                    }
                }
            }
        },
        {
            "label": "Process All Images",
            "type": "shell",
            "command": "npm run process-images",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Update Single Image",
            "type": "shell",
            "command": "npm run update-image -- ${input:imageName}",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "imageName",
            "type": "promptString",
            "description": "Base name of the image to update (e.g., clusteredLights, particleFMAT)"
        }
    ]
}